<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
		<Title>TheTechIdea.Beep.Connectors.HelpScout</Title>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<PackageIcon>SimpleODM.png</PackageIcon>
		<PackageProjectUrl>https://github.com/The-Tech-Idea/</PackageProjectUrl>
		<Copyright>2024</Copyright>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>TheTechIdea.Beep.Connectors.HelpScout</PackageId>
    <Version>1.0.0</Version>
    <Authors>The Tech Idea</Authors>
    <Company>The Tech Idea</Company>
    <Description>HelpScout data source for Beep Data Connectors framework</Description>
    <RepositoryUrl>https://github.com/The-Tech-Idea/BeepDataSources</RepositoryUrl>
    <PackageTags>HelpScout;DataSource;Beep;Connectors;CustomerSupport;HelpDesk</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.9" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="9.0.9" />
    <PackageReference Include="System.Text.Json" Version="9.0.9" />
    <PackageReference Include="TheTechIdea.Beep.DataManagementEngine" Version="2.0.51" />
    <PackageReference Include="TheTechIdea.Beep.DataManagementModels" Version="2.0.101" />
  </ItemGroup>


	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Copy SourceFiles="$(TargetDir)$(MSBuildProjectName).dll" DestinationFolder="$(ProjectDir)..\..\..\..\outputDLL\DataSources\HelpScout\$(TargetFramework)" SkipUnchangedFiles="false" />
	</Target>
	<Target Name="CopyPackage" AfterTargets="Pack">
		<Copy SourceFiles="$(OutputPath)$(PackageId).$(PackageVersion).nupkg" DestinationFolder="..\..\..\..\..\LocalNugetFiles\DataSources" />
	</Target>
	<ItemGroup>
		<None Include="..\..\..\..\InstallationScripts\LogoGFx\128\SimpleODM.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
</Project>