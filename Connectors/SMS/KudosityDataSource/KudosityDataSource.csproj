<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
		<PackageId>TheTechIdea.Beep.Connectors.KudosityDataSource</PackageId>
		<Title>TheTechIdea.Beep.Connectors.KudosityDataSource</Title>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<PackageIcon>SimpleODM.png</PackageIcon>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<RepositoryUrl>https://github.com/The-Tech-Idea/BeepDataSources</RepositoryUrl>
		<PackageProjectUrl>https://github.com/The-Tech-Idea/</PackageProjectUrl>
		<Copyright>2024</Copyright>
		<Company>The Tech Idea</Company>
		<Authors>The Tech Idea</Authors>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TheTechIdea.Beep.DataManagementEngine" Version="2.0.61" />
    <PackageReference Include="TheTechIdea.Beep.DataManagementModels" Version="2.0.119" />
  </ItemGroup>


	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Copy SourceFiles="$(TargetDir)$(MSBuildProjectName).dll" DestinationFolder="$(ProjectDir)..\..\..\..\outputDLL\DataSources\KudosityDataSource\$(TargetFramework)" SkipUnchangedFiles="false" />
	</Target>
	<Target Name="CopyPackage" AfterTargets="Pack">
		<Copy SourceFiles="$(OutputPath)$(PackageId).$(PackageVersion).nupkg" DestinationFolder="..\..\..\..\..\LocalNugetFiles\DataSources" />
	</Target>
	<ItemGroup>
		<None Include="..\..\..\..\InstallationScripts\LogoGFx\128\SimpleODM.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
</Project>