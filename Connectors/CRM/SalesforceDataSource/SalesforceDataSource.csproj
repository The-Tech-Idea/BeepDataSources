<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
		<Title>TheTechIdea.Beep.Connectors.SalesforceDataSource</Title>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<PackageIcon>SimpleODM.png</PackageIcon>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/The-Tech-Idea/</PackageProjectUrl>
		<Copyright>2024</Copyright>
		<Company>The Tech Idea</Company>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>TheTechIdea.Beep.Connectors.SalesforceDataSource</PackageId>
    <Version>1.0.0</Version>
    <Authors>The Tech Idea</Authors>
    <Description>Salesforce CRM Data Source for Beep Data Connectors</Description>
    <RepositoryUrl>https://github.com/The-Tech-Idea/BeepDataSources</RepositoryUrl>
    <PackageTags>beep,datasource,salesforce,crm,connector</PackageTags>
    <RootNamespace>TheTechIdea.Beep.Connectors.Salesforce</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Salesforce SDKs -->
    <!-- OAuth and Authentication -->
    <!-- HTTP Client Extensions -->
    <PackageReference Include="DeveloperForce.Force" Version="2.1.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.2" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="10.0.2" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="System.Text.Json" Version="10.0.2" />
    <PackageReference Include="TheTechIdea.Beep.DataManagementEngine" Version="2.0.61" />
    <PackageReference Include="TheTechIdea.Beep.DataManagementModels" Version="2.0.119" />
  </ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Copy SourceFiles="$(TargetDir)$(MSBuildProjectName).dll" DestinationFolder="$(ProjectDir)..\..\..\..\outputDLL\DataSources\SalesforceDataSource\$(TargetFramework)" SkipUnchangedFiles="false" />
	</Target>
	<Target Name="CopyPackage" AfterTargets="Pack">
		<Copy SourceFiles="$(OutputPath)$(PackageId).$(PackageVersion).nupkg" DestinationFolder="..\..\..\..\..\LocalNugetFiles\DataSources" />
	</Target>
	<ItemGroup>
		<None Include="..\..\..\..\InstallationScripts\LogoGFx\128\SimpleODM.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
</Project>